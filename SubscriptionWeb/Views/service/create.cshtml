@model SubscriptionWeb.Models.Service

@{
    ViewData["Title"] = "Новый сервис";
}

<div class="d-flex justify-content-center mt-4">
    <div class="miku-card p-5" style="width: 100%; max-width: 600px;">
        <h2 class="fw-bold mb-4" style="color: var(--miku-dark);">Новый сервис</h2>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-bold">Название сервиса</label>
                <input asp-for="Name" class="form-control rounded-pill px-3" placeholder="Например: Spotify" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Category" class="form-label fw-bold">Категория</label>
                <input asp-for="Category" class="form-control rounded-pill px-3" placeholder="Музыка, Стриминг, Работа..." />
                <span asp-validation-for="Category" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Website" class="form-label fw-bold">Ссылка на сайт</label>
                <input asp-for="Website" class="form-control rounded-pill px-3" placeholder="https://..." />
                <span asp-validation-for="Website" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Description" class="form-label fw-bold">Описание</label>
                <textarea asp-for="Description" class="form-control px-3" style="border-radius: 20px;" rows="3" placeholder="Краткое описание сервиса..."></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2 mt-2">
                <button type="submit" class="btn-miku flex-grow-1">Создать сервис</button>
                <a asp-action="Index" class="btn-outline-dark-miku text-decoration-none text-center" style="min-width: 120px;">Назад</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}