@model IEnumerable<SubscriptionWeb.Models.Service>

@{
    ViewData["Title"] = "Мои сервисы";
}

<div class="container">
    <div class="miku-card p-5 mb-5 position-relative overflow-hidden" style="background-color: var(--miku-mint-light); border-radius: 40px;">
        <div class="position-relative" style="z-index: 2; max-width: 600px;">
            <!-- Новый заголовок -->
            <h1 class="display-4 fw-bold mb-3" style="color: var(--miku-dark);">ваши подписки под контролем</h1>

            <!-- Новый текст -->
            <p class="fs-5 mb-4" style="color: var(--miku-dark); opacity: 0.8;">
                Управляйте всеми сервисами в едином интерфейсе. Отслеживайте тарифы, даты платежей и забудьте о лишних списаниях.
            </p>

            <a asp-action="Create" class="btn-outline-dark-miku text-decoration-none">Добавить сервис</a>
        </div>

        <!-- Декоративный круг остается -->
        <div class="position-absolute" style="width: 350px; height: 350px; background: white; opacity: 0.15; border-radius: 50%; bottom: -100px; right: -50px; z-index: 1;"></div>
    </div>

    <h2 class="fw-bold mb-4" style="color: var(--miku-dark);">Созданные сервисы ></h2>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="miku-card p-4 shadow-sm border-0">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h4 class="fw-bold m-0" style="color: var(--miku-dark);">@item.Name</h4>
                            <span class="badge rounded-pill" style="background-color: var(--miku-bg); color: var(--miku-mint);">
                                @item.Category
                            </span>
                        </div>
                        <p class="text-muted small mb-4">@item.Description</p>

                        <div class="d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@item.ServiceId" class="btn-outline-dark-miku py-1 px-3 text-decoration-none" style="font-size: 0.85rem;">Edit</a>
                            <form asp-action="Delete" asp-route-id="@item.ServiceId" method="post" onsubmit="return confirm('Удалить сервис и все его тарифы?')">
                                <button type="submit" class="border-0 d-flex justify-content-center align-items-center shadow-sm"
                                        style="width: 32px; height: 32px; background-color: var(--miku-pink); color: white; border-radius: 10px;">
                                    ✕
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- ТА САМАЯ НАДПИСЬ -->
        <div class="text-center py-5 rounded-4" style="background-color: var(--miku-bg); border: 2px dashed #ddd;">
            <div class="fs-1 mb-3">☁️</div>
            <p class="text-muted m-0">У вас пока нет созданных сервисов. Самое время добавить первый!</p>
            <a asp-action="Create" class="text-decoration-none fw-bold mt-2 d-inline-block" style="color: var(--miku-mint);">Создать сейчас</a>
        </div>
    }
</div>