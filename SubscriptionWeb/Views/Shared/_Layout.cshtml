<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Подписки</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SubscriptionWeb.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="content-wrapper">
        <header class="container mt-4 mb-5">
            <nav class="row align-items-center w-100 m-0">

<div class="col-4 d-flex p-0">
    @{
        var avatarPath = User.FindFirst("AvatarPath")?.Value;
    }
    
    <a asp-controller="Account" asp-action="Profile" class="text-decoration-none"
       style="width: 45px; height: 45px; background-color: var(--miku-dark); border-radius: 14px; display:flex; justify-content:center; align-items:center; color:white; overflow:hidden;">
        
        @if (User.Identity.IsAuthenticated && !string.IsNullOrEmpty(avatarPath))
        {
            <img src="@avatarPath" style="width: 100%; height: 100%; object-fit: cover;" alt="Ava" />
        }
        else
        {
            <span style="font-size: 20px;">👤</span>
        }
    </a>
</div>

                
                <!-- Центр: Ссылки -->
                <div class="col-4 d-flex justify-content-center gap-4 p-0">
                    @{
                        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
                    }

                    <!-- НОВАЯ ССЫЛКА НА ГЛАВНУЮ -->
                    <a asp-controller="Home" asp-action="Index"
                       class="text-decoration-none miku-nav-link @(currentController == "Home" ? "active" : "")">
                        Главная
                    </a>

                    <a asp-controller="Service" asp-action="Index"
                       class="text-decoration-none miku-nav-link @(currentController == "Service" ? "active" : "")">
                        Сервисы
                    </a>

                    <a asp-controller="Plan" asp-action="Index"
                       class="text-decoration-none miku-nav-link @(currentController == "Plan" ? "active" : "")">
                        Тарифы
                    </a>
                </div>

                <!-- Право: Информация о пользователе и Выход -->
                <div class="col-4 d-flex justify-content-end align-items-center gap-3 p-0">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <span class="fw-bold d-none d-md-inline" style="color: var(--miku-dark);">Привет, @User.Identity.Name!</span>
                        <a asp-controller="Account" asp-action="Logout" class="btn btn-sm btn-outline-danger rounded-pill px-3">Выход</a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn-outline-dark-miku text-decoration-none">Войти</a>
                        <a asp-controller="Account" asp-action="Register" class="btn-miku text-decoration-none ms-2">Регистрация</a>
                    }
                </div>
            </nav>
        </header>

        <div class="container">
            <main role="main" class="pb-5">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="mt-auto pb-4">
        <div class="container text-center fw-bold" style="color: var(--miku-mint);">
            разработка angerr issues
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>