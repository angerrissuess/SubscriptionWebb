@model SubscriptionWeb.Models.User

@{
    ViewData["Title"] = "Мой профиль";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="miku-card p-5">
                <!-- Верхняя часть: Профиль -->
                <div class="text-center mb-5">
                    <!-- Контейнер аватарки -->
                    <div class="position-relative mx-auto mb-4" style="width: 100px; height: 100px;">
                        <!-- Сама аватарка -->
                        <div style="width: 100px; height: 100px; background-color: var(--miku-dark); border-radius: 30px; display:flex; justify-content:center; align-items:center; color:white; overflow:hidden;">
                            @if (!string.IsNullOrEmpty(Model.AvatarPath))
                            {
                                <img src="@Model.AvatarPath" style="width: 100%; height: 100%; object-fit: cover;" alt="Аватар" />
                            }
                            else
                            {
                                <span style="font-size: 40px;">👤</span>
                            }
                        </div>

                        <!-- Кнопка замены (Карандаш) -->
                        <form asp-action="UpdateAvatar" method="post" enctype="multipart/form-data" id="avatarForm">
                            <label for="avatarInput" class="position-absolute bottom-0 end-0 bg-white shadow-sm d-flex justify-content-center align-items-center"
                                   style="width: 32px; height: 32px; border-radius: 10px; cursor: pointer; border: 2px solid var(--miku-mint-light); transition: 0.2s;">
                                <span style="font-size: 14px;">✏️</span>
                            </label>
                            <!-- Скрытый инпут, который срабатывает при выборе файла -->
                            <input type="file" id="avatarInput" name="avatarFile" class="d-none"
                                   onchange="document.getElementById('avatarForm').submit()" accept="image/*" />
                        </form>
                    </div>

                <!-- Блоки статистики -->
                <div class="row g-4 mb-5">
                    <div class="col-6 col-md-4">
                        <div class="p-3 rounded-4 text-center" style="background-color: #f8fdfe; border: 1px solid var(--miku-mint-light);">
                            <h3 class="fw-bold m-0" style="color: var(--miku-mint);">@ViewBag.ServicesCount</h3>
                            <small class="text-muted">Сервисов</small>
                        </div>
                    </div>
                    <div class="col-6 col-md-4">
                        <div class="p-3 rounded-4 text-center" style="background-color: #f8fdfe; border: 1px solid var(--miku-mint-light);">
                            <h3 class="fw-bold m-0" style="color: var(--miku-mint);">@ViewBag.PlansCount</h3>
                            <small class="text-muted">Тарифов</small>
                        </div>
                    </div>
                    <div class="col-12 col-md-4">
                        <div class="p-3 rounded-4 text-center" style="background-color: #f8fdfe; border: 1px solid var(--miku-mint-light);">
                            <h3 class="fw-bold m-0" style="color: var(--miku-pink);">Активно</h3>
                            <small class="text-muted">Статус аккаунта</small>
                        </div>
                    </div>
                </div>

                <hr style="opacity: 0.1;">

                <!-- Список активных подписок -->
                <div class="mt-5">
                    <h4 class="fw-bold mb-4" style="color: var(--miku-dark);">Активные подписки</h4>

                    @if (ViewBag.UserPlans != null && ((List<SubscriptionWeb.Models.Plan>)ViewBag.UserPlans).Any())
                    {
                        <div class="row g-3">
                            @foreach (var plan in (List<SubscriptionWeb.Models.Plan>)ViewBag.UserPlans)
                            {
                                var daysPassed = (DateTime.UtcNow - plan.StartDate).Days;
                                var daysLeft = Math.Max(0, plan.BillingDays - daysPassed);

                                <div class="col-12">
                                    <div class="p-3 rounded-4 d-flex justify-content-between align-items-center"
                                         style="background-color: white; border: 1px solid #eee;">
                                        <div class="d-flex align-items-center">
                                            <div class="rounded-3 me-3" style="width: 40px; height: 40px; background-color: var(--miku-bg); display: flex; justify-content: center; align-items: center; color: var(--miku-mint);">
                                                💎
                                            </div>
                                            <div>
                                                <div class="fw-bold" style="color: var(--miku-dark);">@plan.Service?.Name</div>
                                                <small class="text-muted">@plan.PlanName</small>
                                            </div>
                                        </div>

                                        <div class="text-end">
                                            @if (daysLeft > 0)
                                            {
                                                <div class="fw-bold" style="color: @(daysLeft <= 5 ? "var(--miku-pink)" : "var(--miku-mint)");">
                                                    Осталось дней: @daysLeft
                                                </div>
                                                <div class="progress mt-1" style="height: 4px; width: 100px;">
                                                    @{
                                                        var percent = (double)daysLeft / plan.BillingDays * 100;
                                                    }
                                                    <div class="progress-bar" style="width: @percent%; background-color: var(--miku-mint);"></div>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger rounded-pill">Истекла</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4 rounded-4" style="background-color: var(--miku-bg); border: 2px dashed #ddd;">
                            <p class="text-muted m-0">У вас пока нет добавленных подписок.</p>
                        </div>
                    }
                </div>

                <!-- Кнопки управления -->
                <div class="mt-5 d-flex gap-2 justify-content-center">
                    <a asp-controller="Service" asp-action="Index" class="btn-miku text-decoration-none">В каталог</a>
                    <a asp-controller="Account" asp-action="Logout" class="btn-outline-dark-miku text-decoration-none">Выйти</a>
                </div>
            </div>
        </div>
    </div>
</div>