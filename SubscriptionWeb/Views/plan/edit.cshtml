@model SubscriptionWeb.Models.Plan

@{
    ViewData["Title"] = "Редактирование тарифа";
}

<div class="d-flex justify-content-center mt-4">
    <div class="miku-card p-5" style="width: 100%; max-width: 600px;">
        <h2 class="fw-bold mb-4" style="color: var(--miku-dark);">Редактировать тариф</h2>

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <!-- КРИТИЧЕСКИ ВАЖНО: Скрытые поля для сохранения данных -->
            <input type="hidden" asp-for="PlanId" />
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="StartDate" />

            <div class="mb-3">
                <label asp-for="ServiceId" class="form-label fw-bold">Сервис</label>
                <select asp-for="ServiceId" class="form-select rounded-pill px-3" asp-items="ViewBag.Services"></select>
                <span asp-validation-for="ServiceId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PlanName" class="form-label fw-bold">Название плана</label>
                <input asp-for="PlanName" class="form-control rounded-pill px-3" placeholder="Например: Premium" />
                <span asp-validation-for="PlanName" class="text-danger small"></span>
            </div>

            <div class="row mb-3">
                <div class="col-6">
                    <label asp-for="Price" class="form-label fw-bold">Стоимость (₽)</label>
                    <input asp-for="Price" class="form-control rounded-pill px-3" />
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>
                <div class="col-6">
                    <label asp-for="BillingDays" class="form-label fw-bold">Период (дней)</label>
                    <input asp-for="BillingDays" class="form-control rounded-pill px-3" />
                    <span asp-validation-for="BillingDays" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn-miku flex-grow-1">Сохранить</button>
                <a asp-action="Index" class="btn-outline-dark-miku text-decoration-none text-center" style="min-width: 120px;">Отмена</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}